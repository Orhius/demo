<Window x:Class="shoesMic.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование товара" Height="600" Width="500">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Артикул*:"/>
            <TextBox x:Name="ArticleTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Название*:"/>
            <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Цена*:"/>
            <TextBox x:Name="PriceTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Поставщик*:"/>
            <TextBox x:Name="SupplierTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Производитель*:"/>
            <TextBox x:Name="ManufacturerTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Категория*:"/>
            <ComboBox x:Name="CategoryComboBox" Margin="0,0,0,10"/>

            <TextBlock Text="Скидка (%):"/>
            <TextBox x:Name="DiscountTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Количество на складе*:"/>
            <TextBox x:Name="StockTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Единица измерения*:"/>
            <TextBox x:Name="UnitTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Имя файла фото:"/>
            <TextBox x:Name="PhotoTextBox" Margin="0,0,0,10"/>
            <TextBlock Text="Например: 1.jpg" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>

            <TextBlock Text="Описание:"/>
            <TextBox x:Name="DescriptionTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK" Width="80" Margin="5" Click="Ok_Click"/>
                <Button Content="Отмена" Width="80" Margin="5" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>