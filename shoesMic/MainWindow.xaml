<Window x:Class="shoesMic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин обуви" Height="600" Width="900">
    <Grid>
        <TabControl>
            <TabItem Header="Пользователи">
                <DataGrid x:Name="UsersGrid" AutoGenerateColumns="True"/>
            </TabItem>
            <TabItem Header="Товары">
                <DataGrid x:Name="ProductsGrid" AutoGenerateColumns="True"/>
            </TabItem>
            <TabItem Header="Заказы">
                <DataGrid x:Name="OrdersGrid" AutoGenerateColumns="True"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>