<!--
    ProductControl.xaml — Карточка товара (UserControl).
    Отображает фото, название, цену, категорию, производителя и описание.
    Code-behind: ProductControl.xaml.cs
-->
<UserControl x:Class="shoesMic.Views.ProductControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="200"
             Margin="5">

    <!-- Рамка карточки -->
    <Border BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="5"
            Margin="5"
            Padding="5">

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Колонка для фото товара -->
                <ColumnDefinition Width="150"/>
                <!-- Колонка для текстовой информации -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Фото товара (загружается из папки Images) -->
            <Image x:Name="ProductImage"
                   Margin="10,0,0,50"
                   Width="140"
                   Height="140"
                   Stretch="Uniform"/>

            <!-- Блок текстовой информации о товаре -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">

                <!-- Название товара -->
                <TextBlock x:Name="NameText"
                           FontSize="16"
                           FontWeight="Bold"/>

                <!-- Цена -->
                <TextBlock x:Name="PriceText"/>

                <!-- Категория -->
                <TextBlock x:Name="CategoryText"/>

                <!-- Производитель -->
                <TextBlock x:Name="ManufacturerText"/>

                <!-- Описание (с переносом строк) -->
                <TextBlock x:Name="DescriptionText" TextWrapping="Wrap"/>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>

