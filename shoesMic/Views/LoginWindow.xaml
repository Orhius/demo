<!--
    LoginWindow.xaml — Окно авторизации пользователя.
    Содержит поля логина/пароля и кнопки входа.
    Code-behind: LoginWindow.xaml.cs
-->
<Window x:Class="shoesMic.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dino Clothes — Авторизация"
        Height="520"
        Width="420"
        Background="#FFF5F5F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>

        <!-- Основной цвет бренда -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2E7D32"/>

        <!-- Стиль основной кнопки (зелёная, скруглённая) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль поля ввода текста -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль поля ввода пароля -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- Карточка формы входа, центрирована на экране -->
        <Border Background="White"
                CornerRadius="14"
                Padding="30"
                Width="358"
                Height="452"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#FFDDDDDD"
                BorderThickness="1">

            <StackPanel>

                <!-- Логотип / заголовок -->
                <TextBlock Text="Dino Clothes"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           TextAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Поле логина -->
                <TextBlock Text="Логин" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginTextBox" Margin="0,0,0,14"/>

                <!-- Поле пароля -->
                <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20"/>

                <!-- Кнопка входа по логину/паролю -->
                <Button Content="Войти"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Login_Click"/>

                <!-- Кнопка входа как гость (без авторизации) -->
                <Button Content="Войти как гость"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="40"
                        Background="{StaticResource PrimaryBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,10,0,0"
                        Click="Guest_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>

