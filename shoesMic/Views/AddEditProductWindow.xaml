<!--
    AddEditProductWindow.xaml — Диалог добавления / редактирования товара.
    Используется в двух режимах: добавление нового и редактирование существующего.
    Code-behind: AddEditProductWindow.xaml.cs
-->
<Window x:Class="shoesMic.Views.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование товара"
        Height="600"
        Width="500">

    <!-- Прокручиваемая область на случай маленького экрана -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">

            <!-- Динамический заголовок (меняется в code-behind) -->
            <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Артикул (обязательное поле, при редактировании — только чтение) -->
            <TextBlock Text="Артикул*:"/>
            <TextBox x:Name="ArticleTextBox" Margin="0,0,0,10"/>

            <!-- Название товара (обязательное поле) -->
            <TextBlock Text="Название*:"/>
            <TextBox x:Name="NameTextBox" Margin="0,0,0,10"/>

            <!-- Цена (обязательное поле, должна быть числом) -->
            <TextBlock Text="Цена*:"/>
            <TextBox x:Name="PriceTextBox" Margin="0,0,0,10"/>

            <!-- Поставщик (обязательное поле) -->
            <TextBlock Text="Поставщик*:"/>
            <TextBox x:Name="SupplierTextBox" Margin="0,0,0,10"/>

            <!-- Производитель (обязательное поле) -->
            <TextBlock Text="Производитель*:"/>
            <TextBox x:Name="ManufacturerTextBox" Margin="0,0,0,10"/>

            <!-- Категория (выбирается из существующих в БД) -->
            <TextBlock Text="Категория*:"/>
            <ComboBox x:Name="CategoryComboBox" Margin="0,0,0,10"/>

            <!-- Скидка в процентах (необязательное поле) -->
            <TextBlock Text="Скидка (%):"/>
            <TextBox x:Name="DiscountTextBox" Margin="0,0,0,10"/>

            <!-- Количество на складе (обязательное поле, целое число) -->
            <TextBlock Text="Количество на складе*:"/>
            <TextBox x:Name="StockTextBox" Margin="0,0,0,10"/>

            <!-- Единица измерения (обязательное поле) -->
            <TextBlock Text="Единица измерения*:"/>
            <TextBox x:Name="UnitTextBox" Margin="0,0,0,10"/>

            <!-- Имя файла фото (необязательное поле) -->
            <TextBlock Text="Имя файла фото:"/>
            <TextBox x:Name="PhotoTextBox" Margin="0,0,0,10"/>
            <TextBlock Text="Например: 1.jpg" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>

            <!-- Текстовое описание товара (необязательное поле) -->
            <TextBlock Text="Описание:"/>
            <TextBox x:Name="DescriptionTextBox"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,0,0,10"/>

            <!-- Кнопки подтверждения и отмены -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="OK"      Width="80" Margin="5" Click="Ok_Click"/>
                <Button Content="Отмена"  Width="80" Margin="5" Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>

