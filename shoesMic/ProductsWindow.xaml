<Window x:Class="shoesMic.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dino Clothes – Каталог товаров"
        Height="850"
        Width="1300"
        Background="#FFF5F5F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2E7D32"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF66BB6A"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#FFE8F5E9"/>
        <SolidColorBrush x:Key="CardBackground" Color="White"/>

        <!-- Кнопка -->
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- ШАПКА -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PrimaryBrush}"
                Height="64"
                Padding="15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Image1.png"
                           Width="36"
                           Height="36"
                           Margin="0,0,10,0"/>
                    <TextBlock Text="Dino Clothes"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource LightTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Пользователь -->
                <TextBlock x:Name="UserLabel"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource LightTextBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Margin="20,0,0,0"/>

                <!-- Выход -->
                <Button Grid.Column="2"
                        Content="Выйти"
                        Style="{StaticResource MainButtonStyle}"
                        Background="#FFD32F2F"
                        Click="Logout_Click"/>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <Border DockPanel.Dock="Top"
                Background="White"
Padding="15"
                Margin="15"
                CornerRadius="10"
                BorderBrush="#FFDDDDDD"
                BorderThickness="1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Добавить товар -->
                <Button x:Name="AddProductBtn"
                        Content="＋ Добавить товар"
                        Style="{StaticResource MainButtonStyle}"
                        Grid.Column="0"
                        Click="AddProduct_Click"/>

                <!-- Поиск -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="15,0">

                    <TextBox x:Name="SearchTextBox"
                             Width="280"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>

                    <Button Content="Найти"
                            Style="{StaticResource MainButtonStyle}"
                            Click="Search_Click"/>
                </StackPanel>

                <!-- Категория -->
                <ComboBox x:Name="CategoryComboBox"
                          Width="200"
                          Grid.Column="2"
                          SelectionChanged="FilterByCategory"/>
            </Grid>
        </Border>

        <!-- СПИСОК ТОВАРОВ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ProductsPanel"
                       Margin="20"
                       HorizontalAlignment="Center"
                       ItemWidth="380"/>
        </ScrollViewer>

    </DockPanel>
</Window>